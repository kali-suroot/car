#include "sys.h" // 系统级头文件，包含基础外设驱动和配置
 
/* ESP8266模块全局状态结构体 */
ESP8266_STR strEsp8266_info; // 存储ESP8266网络连接状态、指令状态等信息
DATA_RCV_STR strEsp8266_rcv; // 串口接收缓冲区，用于调试或AT指令响应
STR_MQTT_INFO strMqtt_Inof; // MQTT连接参数（设备名、密钥、主题等）

/* AT指令配置表：命令、预期响应、超时时间、重试次数 */
CMD_TYPE_STRUCT strEsp8266_cmd[20]={
{.cmd="AT\r\n", .respond = "OK", .wait_time = 2000, .retry_cnt = 3}, // 基础AT指令测试
{.cmd="AT\r\n", .respond = "OK", .wait_time = 2000, .retry_cnt = 3}, // 二次确认模块就绪
{.cmd="AT+CWMODE=1\r\n", .respond = "OK", .wait_time = 2000, .retry_cnt = 3}, // 设置STA模式
{.cmd="AT+RST\r\n", .respond = "OK", .wait_time = 2000, .retry_cnt = 3}, // 模块软复位
{.cmd="AT+CWAUTOCONN=0\r\n", .respond = "OK", .wait_time = 2000, .retry_cnt = 3}, // 关闭自动重连
{.cmd=" ", .respond = "OK", .wait_time = 10000, .retry_cnt = 3}, // 动态填充：连接WiFi（格式：AT+CWJAP="SSID","PWD"）
{.cmd="AT+CIPMUX=0\r\n", .respond = "OK", .wait_time = 2000, .retry_cnt = 3}, // 单连接模式
{.cmd="AT+CIPMODE=1\r\n", .respond = "OK", .wait_time = 2000, .retry_cnt = 3}, // 透传模式
{.cmd=" ", .respond = "OK", .wait_time = 2000, .retry_cnt = 3}, // 动态填充：TCP连接（格式：AT+CIPSTART="TCP","IP",PORT）
{.cmd="AT+CIPSEND\r\n", .respond = "\r\nOK\r\n\r\n>", .wait_time = 2000, .retry_cnt = 3}, // 进入数据发送模式
};

/************************************

函数名：WIFI_RESET_init

功能：初始化ESP8266硬件复位引脚

参数：无

返回值：无
************************************/
void WIFI_RESET_init(void) {
GPIO_InitTypeDef GPIO_InitStruct;
RCC_APB2PeriphClockCmd(ESP8266_RESET_LCK, ENABLE); // 使能复位引脚时钟

GPIO_InitStruct.GPIO_Pin = ESP8266_RESET_PIN; // 配置引脚为推挽输出
GPIO_InitStruct.GPIO_Mode = GPIO_Mode_Out_PP;
GPIO_InitStruct.GPIO_Speed = GPIO_Speed_50MHz;
GPIO_Init(ESP8266_RESET_PORT, &GPIO_InitStruct);
}

 
/************************************

函数名：get_sys_tick

功能：获取系统当前时间戳（单位：毫秒）

参数：无

返回值：系统时间戳
************************************/
unsigned int get_sys_tick(void) {
return sysTickUptime; // 依赖系统时钟实现（如HAL_GetTick()）
}



/************************************

函数名：send_data_to_dev

功能：通过USART2发送数据到ESP8266模块

参数：data-待发送数据指针；len-数据长度

返回值：无
************************************/
void send_data_to_dev(char *data, unsigned short len) {
unsigned int i;
for (i = 0; i < len; i++) { // 轮询方式逐字节发送
while (!(USART2->SR & USART_FLAG_TXE)); // 等待发送缓冲区空
USART2->DR = data[i]; // 写入数据寄存器
while (!(USART2->SR & USART_FLAG_TC)); // 等待发送完成
}
}

/************************************

函数名：fputc

功能：重定向printf到串口（当前未启用）

参数：ch-字符；f-文件指针

返回值：发送的字符
************************************/
int fputc(int ch , FILE *f) {
// 示例：HAL_UART_Transmit(&huart2, (uint8_t *)&ch, 1, 1000);
return ch;
}


/************************************

函数名：USART_rcv_ch

功能：将接收到的字符存入缓冲区，并更新接收状态

参数：ch-接收的字符；str_rcv-接收缓冲区结构体指针

返回值：无
************************************/
void USART_rcv_ch(unsigned char ch, DATA_RCV_STR *str_rcv) {
if (str_rcv->rcv_cnt < 256) { // 缓冲区未满时存入
str_rcv->buff[str_rcv->rcv_cnt] = ch;
str_rcv->rcv_cnt++;
str_rcv->rcv_trick_ms = get_sys_tick(); // 更新最后接收时间戳
}
}


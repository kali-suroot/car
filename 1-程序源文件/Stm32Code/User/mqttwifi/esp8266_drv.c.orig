char ServerIP[128]={"47.109.89.8"};  // MQTT服务器IP地址
int  ServerPort = 1883;               // MQTT服务器端口号

/************************************
 * 函数名：ESP8266_run_handle
 * 功能：ESP8266主状态机，管理网络连接、AT指令流程和MQTT通信
 * 参数：无
 * 返回值：无
 ************************************/
void ESP8266_run_handle(void)
{
    unsigned char ret;                     // 指令执行结果临时变量
    static unsigned int last_mqtt_heart_cnt = 0;  // MQTT心跳包发送计时器（单位：毫秒）
    static unsigned int last_subscirbe_tick = 0;  // 订阅主题重试计时器（单位：毫秒）
     Scheduled();//定时发送数据函数  
    /* 状态1：初始状态或需要复位 */
    if (strEsp8266_info.Net_stu == NET_NULL)
    {
        // 执行硬件复位流程
        if (ESP8266_reset())               // 复位成功返回1
        {
            strEsp8266_info.Net_stu = 1;   // 进入下一状态（AT指令流程）
            // 动态填充AT指令：连接WiFi（ID和PASSWORD为预定义的SSID和密码）
            sprintf(strEsp8266_cmd[5].cmd,"AT+CWJAP=\"%s\",\"%s\"\r\n", ID, PASSWORD);
            // 修改预期响应为"CONNECTED"（WiFi连接成功标志）
            sprintf(strEsp8266_cmd[5].respond,"CONNECTED");
            // 动态填充AT指令：建立TCP连接（ServerIP和ServerPort为MQTT服务器参数）
            sprintf(strEsp8266_cmd[8].cmd,"AT+CIPSTART=\"TCP\",\"%s\",%d\r\n", ServerIP, ServerPort);
        }
    }
    /* 状态2：AT指令执行阶段（从NET_RESET到NET_CIPSEND） */
    else if (strEsp8266_info.Net_stu > 0 && strEsp8266_info.Net_stu <= NET_CIPSEND)
    {
        // 发送当前状态对应的AT指令，并等待响应
        ret = write_cmd(&strEsp8266_cmd[strEsp8266_info.Net_stu]); // 参数：指令结构体指针
        if (ret == 1)           // 指令响应成功
        {
            strEsp8266_info.Net_stu++;     // 切换到下一个AT指令状态
            // 所有AT指令执行完毕（进入透传模式）
            if (strEsp8266_info.Net_stu > NET_CIPSEND)
            {
                memset(strEsp8266_rcv.buff,0,256);  // 清空接收缓冲区
                strEsp8266_rcv.rcv_cnt = 0;          // 接收字符计数器归零
                MQTT_Buff_Init();                    // 初始化MQTT协议缓冲区（需外部实现）
            }
        }
        else if (ret == 2)      // 指令响应超时或重试次数耗尽
        {
            strEsp8266_info.Net_stu = NET_NULL;  // 重置状态，触发重新连接流程
        }
    }
    /* 状态3：TCP连接成功后维持MQTT通信 */
    else 
    {
        period_get_server();    // 周期处理服务器数据（需外部实现，如解析MQTT报文）
        
        /* 心跳包逻辑：每3秒发送一次MQTT Ping */
        if (get_sys_tick() - last_mqtt_heart_cnt >= 3*1000)
        {
            last_mqtt_heart_cnt = get_sys_tick();  // 重置计时器
            mqtt_Ping();                           // 发送MQTT心跳包（需外部实现）
        }
        
        /* 订阅逻辑：连接成功但未订阅时，每秒尝试订阅一次 */
        if (ConnectPack_flag && !SubscribePack_flag) // ConnectPack_flag为MQTT连接标志
        {
            if (get_sys_tick() - last_subscirbe_tick >= 1000)
            {
                last_subscirbe_tick = get_sys_tick();  // 重置计时器
                Mqtt_Subscribe(strMqtt_Inof.sub, 1);   // 订阅主题（sub为动态生成的主题名）
            }
        }
    
        mqtt_Content();  // 处理MQTT数据内容（需外部实现，如处理发布/订阅消息）
        
        /* 连接保持检测：10秒内未收到数据则判定为断线 */
        strEsp8266_info.rcv_idle_cnt = (get_sys_tick() - strEsp8266_rcv.rcv_trick_ms)/1000;
        if (strEsp8266_info.rcv_idle_cnt > 10)  // 单位转换为秒
        {
            strEsp8266_info.Net_stu = NET_NULL;  // 重置连接状态
            strEsp8266_info.offline_cnt++;      // 离线计数器累加（用于统计）
        }
    }
    strEsp8266_info.run_heart++;  // 状态机运行计数器（调试用途，无实际功能）
}
//生成随机数的函数
/*----------------------------------------------------------
 * 函数名：get_round_num
 * 功能：通过ADC采样生成6位随机数（基于硬件噪声特性）
 * 实现原理：读取ADC通道原始值，提取个位/十位数字叠加生成随机序列
 * 返回值：6位十进制随机数（范围：000000-999999）
 * 注：依赖ADC未连接外部信号时的本底噪声
 *---------------------------------------------------------*/
unsigned int get_round_num(void)
{
    unsigned short adc_res;      // ADC原始采样值（12位精度）
    unsigned int round_num = 0;  // 生成的6位随机数
    unsigned char i, S_bit, G_bit; // 临时变量：十位/个位数字

    /* 时钟配置阶段 */
    RCC->APB2ENR |= 0x204;        // 使能APB2总线时钟：bit2=ADC1, bit8=GPIOA
    RCC->CFGR &= 0xFFFF3FFF;      // 清零ADC预分频器位（bit15-14）
    RCC->CFGR |= 0x00008000;      // 设置ADC时钟=主时钟/6（72MHz/6=12MHz）

    /* ADC初始化配置 */
    ADC1->CR2  = 0X000E0000;      // 控制寄存器初始值：bit16-19=1110（保留位）
    ADC1->CR2 |= 0X00000001;      // 使能ADC1（ADON位置1）

    /* ADC校准流程 */
    ADC1->CR2 |= 0X08;            // 初始化校准（CAL位置1）
    while ((ADC1->CR2 & 0x08) != 0); // 等待校准初始化完成（CAL位自动清零）
    
    ADC1->CR2 |= 0X04;            // 开始校准（RSTCAL位置1）
    while ((ADC1->CR2 & 0x04) != 0); // 等待校准完成（RSTCAL位自动清零）

    /* 采样时间配置 */
    ADC1->SMPR2 = 0X001C000;      // 通道4采样时间配置：480周期（bit14-12=111）

    /* 随机数生成核心逻辑 */
    for (i = 0; i < 6; i++)       // 生成6位随机数
    {
        ADC1->CR2 |= 0X00500000;  // 启动单次转换：bit22=SWSTART（启动）, bit20=EXTTRIG（使能触发）
        while (!(ADC1->SR & 0x02)); // 等待转换完成（EOC位置1）
        adc_res = ADC1->DR;       // 读取转换结果（自动清除EOC标志）

        /* 数字处理：取ADC值的个位和十位相加 */
        G_bit = adc_res%10;       // 提取个位数字（0-9）
        S_bit = (adc_res/10)%10;  // 提取十位数字（0-9）
        S_bit += G_bit;           // 数字叠加（0-18）
        
        /* 构建6位数：每次循环左移1位并叠加新值 */
        round_num *= 10;          // 十进制左移（等效于<<4位二进制）
        round_num += S_bit;       // 添加新生成的数字（实际取S_bit%10更合理，代码未实现）
    }
    
    return round_num; // 示例：ADC采样值为1234 → G=4, S=3 → 7 → 最终数类似777777（需改进算法）
}
 


//此处宏定义不作为MQTT连接参数  只作为MQTT连接参数和随机数拼接时的原参
#define  DEVICENAME      "DEVICENAME" 
#define  PRODUCTKEY      "PRODUCTKEY"
#define  DEVICESECRE     "DEVICESECRE" 
#define  SUBSCRIBE_TOPIC  "Sub"      
#define  P_TOPIC_NAME     "Pub"     
void Mqtt_Parameter_init(void){

	
	 memset((char *)&strMqtt_Inof,0,sizeof(strMqtt_Inof));
   strMqtt_Inof.Round_num=get_round_num()%1000000;//随机数赋值
	  //给mqtt连接参数赋予随机数
	 sprintf(strMqtt_Inof.device_name,"%s%06d",DEVICENAME,strMqtt_Inof.Round_num) ;
	 sprintf(strMqtt_Inof.key,"%s%06d",PRODUCTKEY,strMqtt_Inof.Round_num) ;
	 sprintf(strMqtt_Inof.secre,"%s%06d",DEVICESECRE,strMqtt_Inof.Round_num) ;
	 sprintf(strMqtt_Inof.sub,"%s%06d",SUBSCRIBE_TOPIC,strMqtt_Inof.Round_num) ;
	 sprintf(strMqtt_Inof.pub,"%s%06d",P_TOPIC_NAME,strMqtt_Inof.Round_num) ;
}


//向MQTT服务器发布消息
void mqttPublic(void)
{
    char Send[256];
    sprintf(Send,
            "{\"sensor1\":%d,\"sensor2\":%d,\"sensor3\":%d,\"sensor4\":%d,\"sensor5\":%d,\"sensor6\":%d,\"sensor7\":%d,\"sensor8\":%d,\"sensor9\":%d,\"sensor10\":%d,\"sensor11\":%d,\"sensor12\":%d,\"sensor13\":%d,\"sensor14\":%d,\"sensor15\":%d,\"sensor16\":%d,\"sensor17\":%d}",
            SensorData.Fumes, SensorData.Lllumination, SensorData.TempInt, SensorData.HumiInt, SensorData.Flame, System.BurglarFlag, SensorData.HumanBody, Threshold.Smoke_Threshold, Threshold.Lighting_Threshold,
            Threshold.Temperature_Threshold, Threshold.Humidity_Threshold,System.Fan,System.Water_Pump, System.Lamplight,System.Air_Conditioning, System.Curtain,System.Buzzer);
    //烟雾 光照  温度  湿度	火焰	防盗状态 人体监测		烟雾阈值  光照阈值   温度阈值  湿度阈值
    mqtt_PublishQs0(strMqtt_Inof.pub, Send, strlen(Send));
}
/*-------------------------------------------
 * 函数名：Scheduled
 * 功能：定时触发MQTT数据发布（1秒周期）
 * 实现逻辑：
 *   1. 每隔1秒设置发布标志位
 *   2. 当标志位有效且网络/订阅状态就绪时执行发布
 * 依赖条件：
 *   - strEsp8266_info.Net_stu > NET_CIPSEND：网络透传模式已建立
 *   - SubscribePack_flag：MQTT主题订阅成功标志
 *-------------------------------------------*/
void Scheduled (void)
{
    static unsigned int mqtt_pub_cnt = 0 ;  // 发布周期计时器（单位：毫秒）
    
    /* 定时器逻辑：每秒触发一次标志位 */
    if (get_sys_tick() - mqtt_pub_cnt >= 1000)  // 检测1秒间隔
    {
        mqtt_pub_cnt = get_sys_tick();        // 重置计时器
        System.mqttflag = 1;                  // 设置MQTT发布触发标志
    }
    
    /* 发布执行逻辑 */
    if(System.mqttflag)  // 标志位有效时进入
    {
        /* 网络和订阅状态双重验证 */
        if (strEsp8266_info.Net_stu > NET_CIPSEND && SubscribePack_flag) 
        {
            mqttPublic();  // 执行MQTT数据发布（向预设主题发送消息）
        }
        System.mqttflag = 0;  // 强制清除标志位（无论是否成功发布）
    }
}


     /*******************************
       显示链接参数
    	 NET:是连接状态  数字5是没开热点 数字9是热点没有网络
		   MQ_CNT:是服务器连接状态 0是没有连接  1是连接成功    后面一个数字表示重连次数
       Name:需用用手机开启的热点名称
       Pass:热点密码
       热点频段必须是2.4		
    	******************/
void MqttCon_Display(void){
        oled_ShowString(0, 0, (unsigned char *)"NET:", 16);
        oled_ShowString(0, 2, (unsigned char *)"MQ_CNT", 16);
        OLED_ShowDNum(60, 0, strEsp8266_info.Net_stu, 16);
        OLED_ShowDNum(60, 2, strEsp8266_info.MQTT_Connect_flag, 16);
        OLED_ShowDNum(100, 2, strEsp8266_info.offline_cnt, 16);
        oled_ShowString(16 * 0, 2 * 2, (u8 *)"Name:", 16);
			  oled_ShowString(16 * 3, 2 * 2, (u8 *)ID, 16);
        oled_ShowString(16 * 0, 2 * 3, (u8 *)"Pass:", 16);
			  oled_ShowString(16 * 3, 2 * 3, (u8 *)PASSWORD, 16);
        //        oled_ShowString(0, 2, (unsigned char *)"CMD", 16);
        //        oled_ShowString(0, 4, (unsigned char *)"RCV_CN", 16);
        //        OLED_ShowDNum(60, 2, strEsp8266_info.run_heart, 16);
        //        OLED_ShowDNum(60, 4, strEsp8266_info.rcv_idle_cnt, 16);
}

	       /**************
    	显示生成的订阅主题和发布主题
		  为了避免高并发的出现采用随机数拼接的方法来生成主题
		  在app上只需要按照显示屏出现的主题来填写 每一次重启单片机都会生成不同的主题
    	********************/
void Topic_Display(void){

        oled_ShowString(16 * 0, 2 * 0, (u8 *)"Sub:", 16);
        oled_ShowString(16 * 0, 2 * 1, (u8 *)strMqtt_Inof.pub, 16);
        oled_ShowString(16 * 0, 2 * 2, (u8 *)"Pub:", 16);
        oled_ShowString(16 * 0, 2 * 3, (u8 *)strMqtt_Inof.sub, 16);

}


/*********
 if ((isKey1) && (InterFace == 0)) { //若按键1按下
        isKey1 = isKey2 = isKey3 = isKey4 = 0; //清除按键按下标志
        oled_Clear();
        OperateMode++;
    }



   if ((isKey1) && (InterFace != 0)) {
        InterFace = 0;
        isKey1 = 0;
        oled_Clear();
    }

 //标志位限制
    if (OperateMode >= 4) {
        OperateMode = 0;
    }


//在显示页面使用按键切换不同的页面
    if (isKey2) {
        isKey2 = 0;
        oled_Clear();
        InterFace = 1;
    }

    if (isKey3) {
        isKey3 = 0;
        oled_Clear();
        InterFace = 2;
    }

    if (isKey4) {
        isKey4 = 0;
        oled_Clear();
        InterFace = 3;
    }



//调用显示mqtt连接状态参数
    if (InterFace == 2) {
     MqttCon_Display();
    }

//调用显示订阅主题的参数
    if (InterFace == 3) {
    Topic_Display();    
    }

********/

/************************************

函数名：USARTx_RCVHandler

功能：通用USART接收中断处理函数

参数：USARTX-串口外设指针

返回值：无
************************************/
void USARTx_RCVHandler(USART_TypeDef *USARTX) {
unsigned char ch;
if((USARTX->SR & USART_FLAG_RXNE) || (USARTX->SR & USART_FLAG_ORE)) {
ch = USARTX->DR; // 读取数据寄存器以清除标志位
USART_ClearFlag(USARTX, USART_FLAG_RXNE);
if (USARTX == USART2) { // 仅处理USART2的数据（ESP8266通信）
USART_rcv_ch(ch, &strEsp8266_rcv); // 存入接收缓冲区
}
}
}

/************************************

函数名：USART2_IRQHandler

功能：USART2中断服务函数，调用通用处理逻辑

参数：无

返回值：无
************************************/
void USART2_IRQHandler(void) {
USARTx_RCVHandler(USART2);
}
//返回值
/************************************

函数名：write_cmd

功能：发送AT指令并等待响应，处理重试逻辑

参数：strCMD-指令结构体指针

返回值：1-成功；2-超时；0-处理中
************************************/
unsigned char write_cmd(CMD_TYPE_STRUCT *strCMD) {
char *pStr = NULL;
if (strEsp8266_info.Cmd_stu == 0) { // 状态0：发送指令
send_data_to_dev(strCMD->cmd, strlen(strCMD->cmd)); // 发送指令
strEsp8266_info.Cmd_stu = 1; // 切换为等待响应状态
strEsp8266_info.cmd_send_trick = get_sys_tick(); // 记录发送时间
memset(strEsp8266_rcv.buff,0,256); // 清空接收缓冲区
strEsp8266_rcv.rcv_cnt = 0;
} else if (strEsp8266_info.Cmd_stu == 1) { // 状态1：等待响应
if (get_sys_tick() - strEsp8266_info.cmd_send_trick < strCMD->wait_time) {
if (strEsp8266_rcv.rcv_cnt >= 2) { // 至少接收到2字节后开始匹配
pStr = strstr((char *)strEsp8266_rcv.buff, strCMD->respond);
if (pStr) { // 匹配到预期响应
strEsp8266_info.Cmd_stu = 0;
strEsp8266_info.retry_cnt = 0;
return 1; // 成功
}
}
} else { // 超时处理
strEsp8266_info.Cmd_stu = 0;
strEsp8266_info.retry_cnt++;
if(strEsp8266_info.retry_cnt > strCMD->retry_cnt) {
strEsp8266_info.retry_cnt = 0;
return 2; // 重试次数耗尽，返回失败
}
}
}
return 0; // 处理中
}



/************************************

函数名：ESP8266_reset

功能：硬件复位ESP8266模块（拉低复位引脚250ms后恢复）

参数：无

返回值：1-复位完成；0-处理中
************************************/
unsigned char ESP8266_reset(void) {
static unsigned int reset_start_cnt = 0;
static unsigned char reset_stu = 0;
if (reset_stu == 0) { // 阶段0：拉低复位引脚
reset_stu = 1;
reset_start_cnt = get_sys_tick();
ESP8266_RESET_SET_L; // 拉低
} else if (reset_stu == 1) { // 阶段1：保持低电平250ms
if (get_sys_tick() - reset_start_cnt > 250) {
reset_stu = 2;
reset_start_cnt = get_sys_tick();
ESP8266_RESET_SET_H; // 恢复高电平
}
} else if (reset_stu == 2) { // 阶段2：等待250ms后完成
if (get_sys_tick() - reset_start_cnt > 250) {
reset_stu = 0;
return 1; // 复位完成
}
}
return 0; // 处理中
}


